# =============================================================================
# PR Party — Environment Variables
# =============================================================================
# Copy this file to backend/.env (or .env in repo root) and fill in real values.
# NEVER commit the populated .env — it is gitignored by design.
#
# Read SECURITY_AUDIT.md before publishing this repo or rotating credentials.
# =============================================================================


# -----------------------------------------------------------------------------
# IBM watsonx.ai — REQUIRED
# -----------------------------------------------------------------------------
# Create credentials at: https://cloud.ibm.com/catalog/services/watsonx-ai
# After provisioning the service, retrieve:
#   - API key:    IBM Cloud → Manage → Access (IAM) → API keys
#   - Project ID: watsonx.ai console → Projects → your project → Manage tab
# The IAM token issued from this key expires every 60 minutes; the backend
# refreshes it automatically with a 5-minute safety margin.

WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com


# -----------------------------------------------------------------------------
# Granite / watsonx model configuration
# -----------------------------------------------------------------------------
# Pick the model the voice rewriter calls. Defaults work for the fixtures.
# Override with any model your watsonx project has access to.
#
# Tested:
#   ibm/granite-8b-code-instruct                       (default, ~fast)
#   meta-llama/llama-3-3-70b-instruct                  (~higher quality, slower)
#   meta-llama/llama-4-maverick-17b-128e-instruct-fp8  (current preferred)

GRANITE_MODEL_ID=ibm/granite-8b-code-instruct
GRANITE_MAX_TOKENS=4096
GRANITE_TEMPERATURE=0.3


# -----------------------------------------------------------------------------
# GitHub API — OPTIONAL (only needed for live PR analysis)
# -----------------------------------------------------------------------------
# Personal access token: https://github.com/settings/tokens
# Required scopes:
#   - public_repo   (analyze public repos with the 5,000 req/h limit)
#   - repo          (analyze private repos as well)
#
# Leave empty to use unauthenticated access (60 req/h, public repos only).
# Without a token you can still demo with the bundled fixtures.

GITHUB_TOKEN=


# -----------------------------------------------------------------------------
# Application settings
# -----------------------------------------------------------------------------
# Logging verbosity for structlog. INFO is reasonable; DEBUG is noisy.

LOG_LEVEL=INFO

# Comma-separated list of origins allowed by FastAPI CORS middleware.
# Include any host the Next.js frontend may run on (dev + preview + prod).

CORS_ORIGINS=http://localhost:3000,http://localhost:3001


# =============================================================================
# Frontend — apps/web/.env.local
# =============================================================================
# The Next.js frontend reads ONE variable from its own .env.local. Default
# is http://localhost:8000, so you only need to override this when the
# backend lives elsewhere (deployed preview, container network, ngrok, etc).
#
# File path: apps/web/.env.local  (gitignored)
# Used at:   apps/web/lib/api/client.ts, apps/web/lib/api/encounter-store.ts

# NEXT_PUBLIC_API_URL=http://localhost:8000


# =============================================================================
# Auxiliary regeneration scripts — apps/web/.env.local (OPTIONAL)
# =============================================================================
# Only needed if you plan to regenerate sprites or island art. The committed
# sprite PNGs in apps/web/public/ are sufficient for the demo; you can skip
# this block entirely if you are not re-running the generators.
#
# Stored in apps/web/.env.local (NOT in backend/.env), because the scripts
# load that file directly: see scripts/pixellab/client.py, scripts/gemini/generate_island.py
#
# PixelLab v2 REST API — sprite generation. Token at https://app.pixellab.ai/account
# PIXELLAB_API_TOKEN=your_pixellab_token_here
#
# Google Gemini API key — painterly island generation (gemini-2.5-flash-image).
# Key at https://console.cloud.google.com/apis/credentials
# GEMINI_API_KEY=your_gemini_api_key_here
