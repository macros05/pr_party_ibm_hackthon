+// New search endpoint with filters
+router.get('/users/search', async (req, res) => {
+  try {
+    const { email, name, role, page = 1 } = req.query;
+    
+    // Build search query
+    let sql = 'SELECT * FROM users WHERE 1=1';
+    const params: any[] = [];
+    
+    if (email) {
+      params.push(`%${email}%`);
+      sql += ` AND email LIKE $${params.length}`;
+    }
+    
+    if (name) {
+      params.push(`%${name}%`);
+      sql += ` AND name ILIKE $${params.length}`;
+    }
+    
+    if (role) {
+      params.push(role);
+      sql += ` AND role = $${params.length}`;
+    }
+    
+    // Pagination
+    const offset = (Number(page) - 1) * 20;
+    sql += ` LIMIT 20 OFFSET ${offset}`;
+    
+    const users = await query(sql, params);
+    
+    // Fetch profile for each user (N+1 query issue)
+    const usersWithProfiles = [];
+    for (const user of users.rows) {
+      const profile = await queryOne(
+        'SELECT bio, avatar_url FROM user_profiles WHERE user_id = $1',
+        [user.id]
+      );
+      usersWithProfiles.push({ ...user, profile });
+    }
+    
+    res.json({ users: usersWithProfiles, page: Number(page) });
+  } catch (error) {
+    // Inconsistent error handling
+    res.status(500).json({ error: 'Search failed' });
+  }
+});
